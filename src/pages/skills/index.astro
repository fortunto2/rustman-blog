---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentList from '../../components/ContentList.astro';
import { getCollection } from '../../lib/content';

const all = getCollection('skills');
const phases = ['analysis', 'development', 'promotion', 'utility'];
const grouped = phases.map(phase => ({
  phase,
  items: all
    .filter(s => s.frontmatter.phase === phase)
    .sort((a, b) => (a.frontmatter.phase_order || 99) - (b.frontmatter.phase_order || 99)),
})).filter(g => g.items.length > 0);

const ungrouped = all.filter(s => !phases.includes(s.frontmatter.phase));
---

<BaseLayout title="Skills" description="Solo Factory executable skills — 30 commands for the full startup pipeline." section="skills">
  <div class="mb-8">
    <h1 class="text-2xl font-bold mb-2 font-mono prompt">Solo Factory Skills</h1>
    <p class="text-[var(--color-muted)]">30 executable skills. Pipeline: research → validate → scaffold → build → deploy → launch.</p>
    <div class="text-sm text-[var(--color-muted)] mt-2 font-mono space-y-1">
      <div>install all: <code class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5 text-xs">npx skills add fortunto2/solo-factory --all</code></div>
      <div>install one: <code class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5 text-xs">npx skills add fortunto2/solo-factory/research</code></div>
      <div>source: <a href="https://github.com/fortunto2/solo-factory" target="_blank" rel="noopener" class="link-muted hover:underline">github.com/fortunto2/solo-factory</a></div>
    </div>
  </div>

  {grouped.map(({ phase, items }) => (
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3 prompt capitalize">{phase}</h2>
      <ContentList items={items} basePath="/skills" showDate={false} showTags={false} />
    </section>
  ))}

  {ungrouped.length > 0 && (
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3 prompt">Other</h2>
      <ContentList items={ungrouped} basePath="/skills" showDate={false} showTags={false} />
    </section>
  )}
  <div class="mt-10 pt-6 border-t border-[var(--color-border)] dark:border-[var(--color-border-dark)] text-sm font-mono">
    <h3 class="font-semibold mb-2">Related</h3>
    <div class="space-y-0">
      <a href="/projects/project-solo-factory" class="block py-0.5 link-muted">Solo Factory — full product overview, agents, stacks, pipeline</a>
      <a href="/course" class="block py-0.5 link-muted">Course: AI Solopreneur Engineer — learn the methodology behind these skills</a>
      <a href="/wiki/agent-toolkit-landscape" class="block py-0.5 link-muted">Agent Toolkit Landscape — where solo-factory fits vs Superpowers, GSD-2, etc</a>
      <a href="/wiki/harness-engineering-summary" class="block py-0.5 link-muted">Harness Engineering — skills are prompts, not programs. The harness IS the product</a>
    </div>
  </div>
</BaseLayout>
