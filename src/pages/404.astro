---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found.">
  <div class="text-center py-20">
    <h1 class="text-3xl font-bold mb-4">404</h1>
    <p class="text-[var(--color-muted)] mb-6">Page not found.</p>
    <a href="/" class="text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] hover:underline">Back to home</a>
  </div>
</BaseLayout>
