---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentList from '../../components/ContentList.astro';
import { getCollection } from '../../lib/content';

const posts = getCollection('posts');
---

<BaseLayout title="Posts" description="Long-form articles on principles, methodology, and frameworks." section="posts">
  <div class="mb-8">
    <h1 class="text-2xl font-bold mb-2 font-mono prompt">Posts</h1>
    <p class="text-[var(--color-muted)]">Pillar articles — principles, methodology, and frameworks in depth.</p>
  </div>

  <ContentList items={posts} basePath="/posts" showDate={true} showTags={true} />

  {posts.length === 0 && <p class="text-[var(--color-muted)]">No posts yet.</p>}
</BaseLayout>
