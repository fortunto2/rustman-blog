---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getAllContent } from '../lib/content';

const posts = getCollection('posts');
const projects = getCollection('projects');
const recent = getAllContent().slice(0, 30);

// Split into two groups by tags
const openSource = projects.filter(p => p.frontmatter.tags?.includes('open-source'));
const products = projects.filter(p => !p.frontmatter.tags?.includes('open-source'));

// Priority order for open source: solograph, solo-factory, rust projects first
const osPriority = ['project-solograph', 'project-solo-factory', 'project-openai-oxide', 'project-rust-code', 'project-airq'];
openSource.sort((a, b) => {
  const ai = osPriority.indexOf(a.slug);
  const bi = osPriority.indexOf(b.slug);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});

// Priority order for products: SuperDuperAI first, then recent
const prodPriority = ['project-superduperai', 'project-superstoryboard'];
products.sort((a, b) => {
  const ai = prodPriority.indexOf(a.slug);
  const bi = prodPriority.indexOf(b.slug);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});
---

<BaseLayout>
  <section class="mb-12 flex items-center gap-5">
    <img src="/avatar.jpg" alt="Rustam Salavatov" class="w-16 h-16 rounded-full" width="64" height="64" />
    <div>
      <h1 class="text-3xl font-bold mb-1">rustman</h1>
      <p class="text-[var(--color-muted)] text-lg">Solo founder building products with AI. Shipping fast, learning in public.</p>
    </div>
  </section>

  {openSource.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4">Open Source</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {openSource.map(p => (
          <a href={`/projects/${p.slug}`} class="block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] rounded-lg p-4 hover:border-[var(--color-accent)] transition-colors">
            <h3 class="font-medium">{p.frontmatter.title}</h3>
            {p.frontmatter.tags && (
              <div class="flex flex-wrap gap-1.5 mt-1.5">
                {p.frontmatter.tags.filter(t => t !== 'project' && t !== 'open-source').slice(0, 4).map(tag => (
                  <span class="text-xs bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5 rounded">{tag}</span>
                ))}
              </div>
            )}
            {p.frontmatter.description && (
              <p class="text-sm text-[var(--color-muted)] mt-1.5 line-clamp-2">{p.frontmatter.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  {products.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4">Products</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {products.map(p => (
          <a href={`/projects/${p.slug}`} class="block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] rounded-lg p-4 hover:border-[var(--color-accent)] transition-colors">
            <h3 class="font-medium">{p.frontmatter.title}</h3>
            {p.frontmatter.description && (
              <p class="text-sm text-[var(--color-muted)] mt-1 line-clamp-2">{p.frontmatter.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <h2 class="text-xl font-semibold mb-6">Recent</h2>
    <div class="space-y-5">
      {recent.map(entry => (
        <article class="group">
          <a href={`/${entry.section}/${entry.slug}`} class="block">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs uppercase text-[var(--color-muted)] bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5 rounded">{entry.section}</span>
              <span class="text-xs text-[var(--color-muted)]">{entry.frontmatter.created || entry.frontmatter.date}</span>
            </div>
            <h3 class="font-medium group-hover:text-[var(--color-accent)] dark:group-hover:text-[var(--color-accent-dark)] transition-colors">
              {entry.frontmatter.title || entry.slug}
            </h3>
            {entry.frontmatter.description && (
              <p class="text-sm text-[var(--color-muted)] mt-1 line-clamp-1">{entry.frontmatter.description}</p>
            )}
          </a>
        </article>
      ))}
    </div>
  </section>

  {recent.length === 0 && (
    <p class="text-[var(--color-muted)]">No content yet. Run <code>pnpm collect</code> to pull from wiki.</p>
  )}
</BaseLayout>
