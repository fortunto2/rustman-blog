---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentList from '../components/ContentList.astro';
import { SITE, HERO_CARDS, PROJECT_PRIORITY } from '../lib/config';
import { getCollection, getAllContent } from '../lib/content';

const posts = getCollection('posts');
const projects = getCollection('projects');
const recent = getAllContent().slice(0, 30);

const openSource = projects.filter(p => p.frontmatter.tags?.includes('open-source'));
const products = projects.filter(p => !p.frontmatter.tags?.includes('open-source'));

const sortByPriority = (list: typeof projects, priority: readonly string[]) =>
  list.sort((a, b) => {
    const ai = priority.indexOf(a.slug);
    const bi = priority.indexOf(b.slug);
    return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
  });

sortByPriority(openSource, PROJECT_PRIORITY.openSource);
sortByPriority(products, PROJECT_PRIORITY.products);
---

<BaseLayout>
  <section class="mb-10 flex items-center gap-5">
    <img src={SITE.author.avatar} alt={SITE.author.name} class="w-16 h-16 rounded-full" width="64" height="64" />
    <div>
      <h1 class="text-3xl font-bold mb-1 font-mono">rustman<span class="text-[var(--color-accent)] dark:text-[var(--color-accent-dark)]">.</span></h1>
      <p class="text-[var(--color-muted)] text-lg">AI engineer & solo founder. Building tools, shipping fast, learning in public.</p>
    </div>
  </section>

  <section class="mb-12">
    <div class="grid gap-3 sm:grid-cols-2">
      {HERO_CARDS.map(card => (
        <a href={card.href} class="card-glow block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4 hover:border-[var(--color-accent)] transition-all">
          <h3 class="font-medium font-mono text-sm">{card.title}</h3>
          <p class="text-sm text-[var(--color-muted)] mt-1">{card.description}</p>
        </a>
      ))}
    </div>
    <div class="mt-4 flex flex-wrap items-center gap-3 font-mono text-sm">
      <a href={SITE.contact.calendar} target="_blank" rel="noopener" class="inline-block border border-[var(--color-accent)] dark:border-[var(--color-accent-dark)] text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] px-4 py-2 hover:bg-[var(--color-accent)] hover:text-white dark:hover:bg-[var(--color-accent-dark)] dark:hover:text-black transition-colors">Book a call &rarr;</a>
      <a href={SITE.social.linkedin} target="_blank" rel="noopener" class="link-muted">LinkedIn</a>
      <a href={SITE.social.github} target="_blank" rel="noopener" class="link-muted">GitHub</a>
      <a href={SITE.social.telegram} target="_blank" rel="noopener" class="link-muted">Telegram</a>
      <a href={`mailto:${SITE.contact.email}`} class="link-muted">Email</a>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Posts</h2>
      <ContentList items={posts} basePath="/posts" showDate={true} showTags={false} />
    </section>
  )}

  {openSource.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Open Source</h2>
      <ContentList items={openSource} basePath="/projects" showDate={false} showTags={true} />
    </section>
  )}

  {products.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Products</h2>
      <ContentList items={products} basePath="/projects" showDate={false} showTags={true} />
    </section>
  )}

  <section>
    <h2 class="text-xl font-semibold mb-4 prompt">Recent</h2>
    <ContentList items={recent} showSection={true} showDate={true} />
  </section>

  {recent.length === 0 && (
    <p class="text-[var(--color-muted)]">No content yet. Run <code>pnpm collect</code> to pull from wiki.</p>
  )}
</BaseLayout>
