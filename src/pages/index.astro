---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentList from '../components/ContentList.astro';
import { getCollection, getAllContent } from '../lib/content';

const posts = getCollection('posts');
const projects = getCollection('projects');
const recent = getAllContent().slice(0, 30);

const openSource = projects.filter(p => p.frontmatter.tags?.includes('open-source'));
const products = projects.filter(p => !p.frontmatter.tags?.includes('open-source'));

const osPriority = ['project-solograph', 'project-solo-factory', 'project-openai-oxide', 'project-rust-code', 'project-airq', 'project-you2idea', 'project-invoice-crm'];
openSource.sort((a, b) => {
  const ai = osPriority.indexOf(a.slug);
  const bi = osPriority.indexOf(b.slug);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});

const prodPriority = ['project-superduperai', 'project-superstoryboard'];
products.sort((a, b) => {
  const ai = prodPriority.indexOf(a.slug);
  const bi = prodPriority.indexOf(b.slug);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});
---

<BaseLayout>
  <section class="mb-12 flex items-center gap-5">
    <img src="/avatar.jpg" alt="Rustam Salavatov" class="w-16 h-16 rounded-full" width="64" height="64" />
    <div>
      <h1 class="text-3xl font-bold mb-1 font-mono">rustman<span class="text-[var(--color-accent)] dark:text-[var(--color-accent-dark)]">.</span></h1>
      <p class="text-[var(--color-muted)] text-lg">Solo founder building products with AI. Shipping fast, learning in public.</p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-xl font-semibold mb-2 prompt">AI Solutions & Consulting</h2>
    <p class="text-[var(--color-muted)] mb-4">From 0 to 1: fast MVP development & AI integration for businesses.</p>
    <div class="grid gap-3 sm:grid-cols-2">
      <a href="/wiki/rag-patterns" class="card-glow block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4 hover:border-[var(--color-accent)] transition-all">
        <h3 class="font-medium font-mono text-sm">RAG & Knowledge Systems</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">7 production patterns — from vector search to agentic RAG</p>
      </a>
      <a href="/posts/harness-engineering" class="card-glow block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4 hover:border-[var(--color-accent)] transition-all">
        <h3 class="font-medium font-mono text-sm">AI Agent Development</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">Multi-agent systems, harness engineering, reliable autonomous workflows</p>
      </a>
      <a href="/posts/launch-playbook" class="card-glow block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4 hover:border-[var(--color-accent)] transition-all">
        <h3 class="font-medium font-mono text-sm">Fast MVP Development</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">0→1 in days: validate, build, launch with AI-first stack</p>
      </a>
      <a href="/wiki/context-engineering" class="card-glow block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4 hover:border-[var(--color-accent)] transition-all">
        <h3 class="font-medium font-mono text-sm">Team AI Training</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">Context engineering, prompt design, agent workflows for dev teams</p>
      </a>
    </div>
    <div class="mt-4 flex flex-wrap items-center gap-3 font-mono text-sm">
      <a href="https://calendar.app.google/n4GorZYpiAucGjAE6" target="_blank" rel="noopener" class="inline-block border border-[var(--color-accent)] dark:border-[var(--color-accent-dark)] text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] px-4 py-2 hover:bg-[var(--color-accent)] hover:text-white dark:hover:bg-[var(--color-accent-dark)] dark:hover:text-black transition-colors">Book a call &rarr;</a>
      <a href="https://www.linkedin.com/in/rustam-salavatov/" target="_blank" rel="noopener" class="text-[var(--color-muted)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] transition-colors">LinkedIn</a>
      <a href="https://github.com/fortunto2" target="_blank" rel="noopener" class="text-[var(--color-muted)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] transition-colors">GitHub</a>
      <a href="https://t.me/life2film" target="_blank" rel="noopener" class="text-[var(--color-muted)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] transition-colors">Telegram</a>
      <a href="mailto:info@superduperai.co" class="text-[var(--color-muted)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] transition-colors">Email</a>
    </div>
  </section>

  {openSource.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Open Source</h2>
      <ContentList items={openSource} basePath="/projects" showDate={false} showTags={true} />
    </section>
  )}

  {products.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Products</h2>
      <ContentList items={products} basePath="/projects" showDate={false} showTags={true} />
    </section>
  )}

  {posts.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Pillars</h2>
      <ContentList items={posts} basePath="/posts" showDate={true} showTags={false} />
    </section>
  )}

  <section>
    <h2 class="text-xl font-semibold mb-4 prompt">Recent</h2>
    <ContentList items={recent} showSection={true} showDate={true} />
  </section>

  {recent.length === 0 && (
    <p class="text-[var(--color-muted)]">No content yet. Run <code>pnpm collect</code> to pull from wiki.</p>
  )}
</BaseLayout>
