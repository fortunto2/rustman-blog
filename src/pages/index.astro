---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getAllContent } from '../lib/content';

const posts = getCollection('posts');
const projects = getCollection('projects');
const recent = getAllContent().slice(0, 30);

const openSource = projects.filter(p => p.frontmatter.tags?.includes('open-source'));
const products = projects.filter(p => !p.frontmatter.tags?.includes('open-source'));

const osPriority = ['project-solograph', 'project-solo-factory', 'project-openai-oxide', 'project-rust-code', 'project-airq', 'project-you2idea', 'project-invoice-crm'];
openSource.sort((a, b) => {
  const ai = osPriority.indexOf(a.slug);
  const bi = osPriority.indexOf(b.slug);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});

const prodPriority = ['project-superduperai', 'project-superstoryboard'];
products.sort((a, b) => {
  const ai = prodPriority.indexOf(a.slug);
  const bi = prodPriority.indexOf(b.slug);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});
---

<BaseLayout>
  <section class="mb-12 flex items-center gap-5">
    <img src="/avatar.jpg" alt="Rustam Salavatov" class="w-16 h-16 rounded-full" width="64" height="64" />
    <div>
      <h1 class="text-3xl font-bold mb-1 font-mono">rustman<span class="text-[var(--color-accent)] dark:text-[var(--color-accent-dark)]">.</span></h1>
      <p class="text-[var(--color-muted)] text-lg">Solo founder building products with AI. Shipping fast, learning in public.</p>
    </div>
  </section>

  {openSource.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Open Source</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {openSource.map(p => (
          <a href={`/projects/${p.slug}`} class="card-glow block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4 hover:border-[var(--color-accent)] transition-all">
            <h3 class="font-medium font-mono text-sm">{p.frontmatter.title}</h3>
            {p.frontmatter.tags && (
              <div class="flex flex-wrap gap-1.5 mt-1.5">
                {p.frontmatter.tags.filter(t => t !== 'project' && t !== 'open-source').slice(0, 4).map(tag => (
                  <span class="text-xs font-mono bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5">{tag}</span>
                ))}
              </div>
            )}
            {p.frontmatter.description && (
              <p class="text-sm text-[var(--color-muted)] mt-1.5 line-clamp-2">{p.frontmatter.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  {products.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Products</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {products.map(p => (
          <a href={`/projects/${p.slug}`} class="card-glow block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4 hover:border-[var(--color-accent)] transition-all">
            <h3 class="font-medium">{p.frontmatter.title}</h3>
            {p.frontmatter.description && (
              <p class="text-sm text-[var(--color-muted)] mt-1 line-clamp-2">{p.frontmatter.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  {posts.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4 prompt">Pillars</h2>
      <div class="space-y-3">
        {posts.map(p => (
          <a href={`/posts/${p.slug}`} class="card-glow block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4 hover:border-[var(--color-accent)] transition-all">
            <h3 class="font-medium">{p.frontmatter.title}</h3>
            {p.frontmatter.description && (
              <p class="text-sm text-[var(--color-muted)] mt-1">{p.frontmatter.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mb-12">
    <h2 class="text-xl font-semibold mb-2 prompt">AI Solutions & Consulting</h2>
    <p class="text-[var(--color-muted)] mb-4">From 0 to 1: Fast MVP Development & AI Integration</p>
    <div class="grid gap-3 sm:grid-cols-2">
      <div class="border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4">
        <h3 class="font-medium font-mono text-sm">Business AI Agents</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">Custom agents for workflow automation, customer service, and decision support</p>
      </div>
      <div class="border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4">
        <h3 class="font-medium font-mono text-sm">RAG Systems</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">Intelligent document processing and knowledge base solutions</p>
      </div>
      <div class="border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4">
        <h3 class="font-medium font-mono text-sm">Fast MVP Development</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">Rapid prototyping and 0→1 product development with AI integration</p>
      </div>
      <div class="border border-[var(--color-border)] dark:border-[var(--color-border-dark)] dark:bg-[var(--color-surface-dark)] p-4">
        <h3 class="font-medium font-mono text-sm">Team AI Training</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">Training development teams on AI implementation and best practices</p>
      </div>
    </div>
    <div class="flex flex-wrap gap-2 mt-4 text-xs font-mono">
      <span class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5">LangChain</span>
      <span class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5">OpenAI</span>
      <span class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5">RAG</span>
      <span class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5">FastAPI</span>
      <span class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5">Multi-Agent Systems</span>
      <span class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5">Vector DBs</span>
    </div>
    <div class="mt-4">
      <a href="https://calendar.app.google/n4GorZYpiAucGjAE6" target="_blank" rel="noopener" class="inline-block font-mono text-sm border border-[var(--color-accent)] dark:border-[var(--color-accent-dark)] text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] px-4 py-2 hover:bg-[var(--color-accent)] hover:text-white dark:hover:bg-[var(--color-accent-dark)] dark:hover:text-black transition-colors">Book a call &rarr;</a>
    </div>
  </section>

  <section>
    <h2 class="text-xl font-semibold mb-4 prompt">Recent</h2>
    <div class="space-y-0 font-mono text-sm">
      {recent.map(entry => (
        <a href={`/${entry.section}/${entry.slug}`} class="group flex items-baseline gap-3 py-1 hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] transition-colors">
          <span class="text-xs text-[var(--color-muted)] shrink-0 w-20">{entry.frontmatter.created || entry.frontmatter.date}</span>
          <span class="text-xs uppercase text-[var(--color-muted)] dark:text-[var(--color-accent-dim)] shrink-0 w-16">{entry.section}</span>
          <span class="truncate">{entry.frontmatter.title || entry.slug}</span>
        </a>
      ))}
    </div>
  </section>

  {recent.length === 0 && (
    <p class="text-[var(--color-muted)]">No content yet. Run <code>pnpm collect</code> to pull from wiki.</p>
  )}
</BaseLayout>
