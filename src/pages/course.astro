---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/config';
import { getAllContent } from '../lib/content';

const MODULE_META: Record<number, { title: string; description: string; outcome: string }> = {
  1: { title: 'Mindset & Philosophy', description: 'Why build. What to believe. How to think about risk, creativity, and freedom.', outcome: 'Clear personal manifesto. Decision framework installed.' },
  2: { title: 'Decision Making', description: 'Frameworks for decisions at every level — from epistemics to daily ops.', outcome: 'STREAM framework applied to one real decision. Kill/iterate/scale thresholds set.' },
  3: { title: 'Validation & Launch', description: 'From niche selection to live product with traffic in 5-9 days.', outcome: 'One niche scored via S.E.E.D. Fake-door test run. Go/kill decision made.' },
  4: { title: 'Engineering Foundations', description: 'Schemas first, CLI-first, clean architecture, privacy by design.', outcome: 'Project scaffolded from stack template. CLAUDE.md configured. Pre-commit hooks running.' },
  5: { title: 'AI Agent Engineering', description: 'Harness, memory, context, testing, code review with agents. The core of the course.', outcome: 'Harness file tuned. Memory system configured. Agent does reliable work on your real tasks.' },
  6: { title: 'Solo Factory: The Toolkit', description: 'Claude Code plugin as the practical framework. 30 skills grouped by pipeline phase.', outcome: 'Solo-factory installed. 3-5 skills used on a real project. Custom skill created.' },
  7: { title: 'Case Studies', description: 'Real projects demonstrating the principles. Each one: problem, approach, result, lessons.', outcome: 'Your own project shipped end-to-end using the methodology.' },
};

// Build course from frontmatter course_module + course_order
const all = getAllContent();
const courseItems = all.filter(e => e.frontmatter.course_module);

const modulesMap = new Map<number, typeof courseItems>();
for (const item of courseItems) {
  const mod = Number(item.frontmatter.course_module);
  if (!modulesMap.has(mod)) modulesMap.set(mod, []);
  modulesMap.get(mod)!.push(item);
}

// Sort items within each module by course_order
const modules = [...modulesMap.entries()]
  .sort(([a], [b]) => a - b)
  .map(([id, items]) => ({
    id,
    ...MODULE_META[id],
    items: items.sort((a, b) => Number(a.frontmatter.course_order || 99) - Number(b.frontmatter.course_order || 99)),
  }));

const totalLessons = modules.reduce((acc, m) => acc + m.items.length, 0);

const skills = [
  { phase: 'Analysis', items: [
    { name: 'research', desc: 'Market research, competitors, evidence' },
    { name: 'swarm', desc: 'Parallel 3-agent research' },
    { name: 'validate', desc: 'STREAM scoring + PRD generation' },
    { name: 'stream', desc: 'Decision framework for founder choices' },
    { name: 'sgr', desc: 'Design Schema-Guided Reasoning pipelines' },
    { name: 'you2idea-extract', desc: 'Mine startup ideas from YouTube' },
  ]},
  { phase: 'Development', items: [
    { name: 'scaffold', desc: 'New project from PRD + stack template' },
    { name: 'setup', desc: 'TDD workflow, dev environment' },
    { name: 'plan', desc: 'Spec + phased implementation plan' },
    { name: 'build', desc: 'Execute plan tasks, TDD, commit' },
    { name: 'deploy', desc: 'Push to production' },
    { name: 'review', desc: 'Quality check before ship' },
  ]},
  { phase: 'Promotion', items: [
    { name: 'launch', desc: 'GTM strategy, distribution plan' },
    { name: 'landing-gen', desc: 'Landing page from PRD' },
    { name: 'content-gen', desc: 'Social media pack' },
    { name: 'video-promo', desc: 'Video script + storyboard' },
    { name: 'community-outreach', desc: 'Find communities, draft posts' },
    { name: 'reddit', desc: 'Reddit engagement + karma' },
    { name: 'github-outreach', desc: 'Target competitor dependents' },
    { name: 'seo-audit', desc: 'SEO health check' },
    { name: 'metrics-track', desc: 'PostHog events, funnels, KPIs' },
    { name: 'legal', desc: 'Privacy policy, ToS, GDPR' },
    { name: 'humanize', desc: 'Strip AI patterns from copy' },
  ]},
  { phase: 'Utility', items: [
    { name: 'init', desc: 'First-time solo-factory setup' },
    { name: 'factory', desc: 'Install all skills at once' },
    { name: 'pipeline', desc: 'Chain skills: research to deploy' },
    { name: 'retro', desc: 'Pipeline quality review' },
    { name: 'audit', desc: 'Knowledge base health check' },
    { name: 'memory-audit', desc: 'CLAUDE.md + context budget' },
    { name: 'skill-audit', desc: 'Skill quality review' },
    { name: 'index-youtube', desc: 'Index YouTube transcripts' },
  ]},
];
---

<BaseLayout title="Course: AI Solopreneur Engineer" description="From philosophy to production: 7 modules, 60+ lessons, 30 skills.">
  <div class="mb-10">
    <h1 class="text-2xl font-bold mb-2 font-mono prompt">AI Solopreneur Engineer</h1>
    <p class="text-[var(--color-muted)] mb-4">{modules.length} modules, {totalLessons} lessons. Build AI products solo — principles, frameworks, tools, and real projects.</p>
    <p class="text-sm text-[var(--color-muted)]">Powered by <a href="/projects/project-solo-factory" class="link-muted hover:underline">solo-factory</a> — a Claude Code plugin that implements this methodology as executable skills.</p>
  </div>

  <nav class="mb-10 font-mono text-sm">
    <div class="flex flex-wrap gap-x-4 gap-y-1">
      {modules.map(mod => (
        <a href={`#module-${mod.id}`} class="link-muted">{mod.id}. {mod.title}</a>
      ))}
      <a href="#skills" class="link-muted">Skills</a>
    </div>
  </nav>

  {modules.map(mod => (
    <section class="mb-10" id={`module-${mod.id}`}>
      <h2 class="text-lg font-semibold mb-1 prompt">Module {mod.id}: {mod.title}</h2>
      <p class="text-sm text-[var(--color-muted)] mb-1">{mod.description}</p>
      <p class="text-xs text-[var(--color-accent)] dark:text-[var(--color-accent-dim)] mb-3 font-mono">Result: {mod.outcome}</p>
      <div class="space-y-0 font-mono text-sm">
        {mod.items.map((item, i) => (
          <a href={`/${item.section}/${item.slug}`} class="group flex items-baseline gap-3 py-1 hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] transition-colors">
            <span class="text-xs text-[var(--color-muted)] shrink-0 w-8 text-right">{mod.id}.{i + 1}</span>
            <span class="text-xs uppercase text-[var(--color-muted)] dark:text-[var(--color-accent-dim)] shrink-0 w-14">{item.section}</span>
            <span class="truncate">{item.frontmatter.title || item.slug}</span>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="mb-10" id="skills">
    <h2 class="text-xl font-semibold mb-2 prompt">Solo Factory Skills</h2>
    <p class="text-sm text-[var(--color-muted)] mb-4">Pipeline: <span class="font-mono">research &rarr; validate &rarr; scaffold &rarr; plan &rarr; build &rarr; deploy &rarr; launch</span></p>

    {skills.map(group => (
      <div class="mb-6">
        <h3 class="text-sm font-semibold mb-2 font-mono">{group.phase}</h3>
        <div class="space-y-0 font-mono text-sm">
          {group.items.map(skill => (
            <div class="flex items-baseline gap-3 py-0.5">
              <span class="text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] shrink-0 w-40">/{skill.name}</span>
              <span class="text-[var(--color-muted)] truncate">{skill.desc}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <div class="mt-8 pt-6 border-t border-[var(--color-border)] dark:border-[var(--color-border-dark)] text-sm text-[var(--color-muted)] font-mono">
    <p>New lessons auto-added when wiki pages get <code>course_module</code> in frontmatter.</p>
    <p class="mt-2">
      <a href="/posts/manifest" class="link-muted hover:underline">Manifesto</a> &middot;
      <a href="/projects/project-solo-factory" class="link-muted hover:underline">Solo Factory</a> &middot;
      <a href="https://github.com/fortunto2/solo-factory" class="link-muted hover:underline" target="_blank" rel="noopener">GitHub</a> &middot;
      <a href={SITE.contact.calendar} class="link-muted hover:underline" target="_blank" rel="noopener">Book a call</a>
    </p>
  </div>
</BaseLayout>
