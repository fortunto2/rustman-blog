---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from '../../lib/content';
import { renderMarkdown } from '../../lib/md';

export function getStaticPaths() {
  const articles = getCollection('articles');
  return articles.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const post = renderMarkdown(entry.raw);
post.slug = entry.slug;
---

<BaseLayout title={post.frontmatter.title} description={post.frontmatter.description}>
  <article class="prose dark:prose-invert max-w-none" data-pagefind-body>
    {post.frontmatter.title && !post.hasH1 && (
      <h1>{post.frontmatter.title}</h1>
    )}
    <div class="flex gap-3 text-sm text-[var(--color-muted)] mb-8">
      <time>{post.frontmatter.created || post.frontmatter.date}</time>
      {post.frontmatter.tags && typeof post.frontmatter.tags !== 'string' && post.frontmatter.tags.map(tag => (
        <span class="bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5 rounded text-xs">{tag}</span>
      ))}
    </div>
    <Fragment set:html={post.html} />
  </article>

  {post.frontmatter.source_path && (
    <div class="mt-8 pt-4 border-t border-[var(--color-border)] dark:border-[var(--color-border-dark)] text-sm text-[var(--color-muted)]">
      Source: <code>{post.frontmatter.source_path}</code>
    </div>
  )}
</BaseLayout>
