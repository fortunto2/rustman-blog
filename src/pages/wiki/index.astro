---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from '../../lib/content';

const pages = getCollection('wiki');
const hubs = pages.filter(p => p.frontmatter.type === 'hub');
const concepts = pages.filter(p => p.frontmatter.type === 'concept');
const summaries = pages.filter(p => p.frontmatter.type === 'summary');
---

<BaseLayout title="Wiki" description="Knowledge base — compiled principles, methodology, and patterns.">
  <div class="mb-8">
    <h1 class="text-2xl font-bold mb-2">Wiki</h1>
    <p class="text-[var(--color-muted)]">Compiled knowledge base. Synthesized from raw sources, interlinked.</p>
  </div>

  <div id="wiki-search" class="mb-8"></div>

  {hubs.length > 0 && (
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-4">Topics</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {hubs.map(p => (
          <a href={`/wiki/${p.slug}`} class="block border border-[var(--color-border)] dark:border-[var(--color-border-dark)] rounded-lg p-3 hover:border-[var(--color-accent)] transition-colors">
            <h3 class="font-medium text-sm">{p.frontmatter.title}</h3>
            {p.frontmatter.description && (
              <p class="text-xs text-[var(--color-muted)] mt-1 line-clamp-2">{p.frontmatter.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  {concepts.length > 0 && (
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-4">Concepts</h2>
      <div class="space-y-3">
        {concepts.map(p => (
          <a href={`/wiki/${p.slug}`} class="block group">
            <h3 class="text-sm font-medium group-hover:text-[var(--color-accent)] transition-colors">{p.frontmatter.title}</h3>
            {p.frontmatter.description && (
              <p class="text-xs text-[var(--color-muted)] line-clamp-1">{p.frontmatter.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  {summaries.length > 0 && (
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-4">Source Summaries</h2>
      <div class="space-y-3">
        {summaries.map(p => (
          <a href={`/wiki/${p.slug}`} class="block group">
            <h3 class="text-sm font-medium group-hover:text-[var(--color-accent)] transition-colors">{p.frontmatter.title}</h3>
            {p.frontmatter.description && (
              <p class="text-xs text-[var(--color-muted)] line-clamp-1">{p.frontmatter.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  <script>
    import { PagefindUI } from '@pagefind/default-ui';
    new PagefindUI({
      element: '#wiki-search',
      showSubResults: false,
      showImages: false,
      resetStyles: true,
    });
  </script>

  <style is:global>
    #wiki-search .pagefind-ui__search-input {
      border: 1px solid var(--color-border) !important;
      border-radius: 0.5rem !important;
      padding: 0.5rem 0.75rem !important;
      font-size: 0.875rem !important;
      width: 100% !important;
      background: transparent !important;
      color: inherit !important;
    }
    #wiki-search .pagefind-ui__result-link { color: var(--color-accent) !important; }
    #wiki-search .pagefind-ui__result-excerpt { color: var(--color-muted) !important; font-size: 0.8rem !important; }
  </style>
</BaseLayout>
