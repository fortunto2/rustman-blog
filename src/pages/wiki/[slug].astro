---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackLink from '../../components/BackLink.astro';
import ArticleMeta from '../../components/ArticleMeta.astro';
import SourceFooter from '../../components/SourceFooter.astro';
import { getCollection } from '../../lib/content';
import { renderMarkdown } from '../../lib/md';

export function getStaticPaths() {
  return getCollection('wiki').map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const post = renderMarkdown(entry.raw);
---

<BaseLayout title={post.frontmatter.title} description={post.frontmatter.description} article={{ date: post.frontmatter.created || post.frontmatter.date, tags: post.frontmatter.tags as string[] }}>
  <BackLink href="/wiki" label="Wiki" />
  <article class="prose dark:prose-invert max-w-none" data-pagefind-body data-pagefind-filter="section:wiki">
    {post.frontmatter.title && !post.hasH1 && (
      <h1>{post.frontmatter.title}</h1>
    )}
    <ArticleMeta date={post.frontmatter.created || post.frontmatter.date} type={post.frontmatter.type} tags={post.frontmatter.tags as string[]} />
    <Fragment set:html={post.html} />
  </article>

  <SourceFooter sourceUrls={post.frontmatter.source_url} sourcePath={post.frontmatter.source_path} />
</BaseLayout>
