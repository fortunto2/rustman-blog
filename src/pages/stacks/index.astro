---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentList from '../../components/ContentList.astro';
import { getCollection } from '../../lib/content';

const all = getCollection('stacks');
const stacks = all.filter(s => s.slug !== 'libraries');
const libraries = all.find(s => s.slug === 'libraries');
const librariesList = libraries ? [libraries] : [];
---

<BaseLayout title="Stacks" description="Stack templates — copy and use for your next project.">
  <div class="mb-8">
    <h1 class="text-2xl font-bold mb-2 font-mono prompt">Stack Templates</h1>
    <p class="text-[var(--color-muted)]">Ready-to-use stack configs. Pick one, copy, scaffold your project.</p>
  </div>

  <ContentList items={stacks} basePath="/stacks" showDate={false} showTags={true} />

  {libraries && (
    <div class="mt-10">
      <h2 class="text-xl font-semibold mb-3 prompt">Libraries</h2>
      <p class="text-[var(--color-muted)] mb-3 text-sm">Curated libs by category — not part of default stacks.</p>
      <ContentList items={librariesList} basePath="/stacks" showDate={false} showTags={true} />
    </div>
  )}

  {stacks.length === 0 && <p class="text-[var(--color-muted)]">No stacks yet. Run <code>pnpm collect</code>.</p>}
</BaseLayout>
