---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from '../../lib/content';
import { renderMarkdown } from '../../lib/md';

export function getStaticPaths() {
  return getCollection('stacks').map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const post = renderMarkdown(entry.raw);
---

<BaseLayout title={post.frontmatter.title} description={post.frontmatter.description}>
  <div class="mb-4">
    <a href="/stacks" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)]">&larr; Stacks</a>
  </div>
  <article class="prose dark:prose-invert max-w-none" data-pagefind-body data-pagefind-filter-section="stack">
    {post.frontmatter.title && !post.hasH1 && (
      <h1>{post.frontmatter.title}</h1>
    )}
    <Fragment set:html={post.html} />
  </article>

  {post.frontmatter.source_path && (
    <div class="mt-6 pt-4 border-t border-[var(--color-border)] dark:border-[var(--color-border-dark)] text-sm text-[var(--color-muted)]">
      Source: <code>{post.frontmatter.source_path}</code>
    </div>
  )}
</BaseLayout>
