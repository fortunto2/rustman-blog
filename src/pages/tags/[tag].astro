---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentList from '../../components/ContentList.astro';
import { getAllTags } from '../../lib/content';

export function getStaticPaths() {
  const tags = getAllTags();
  return [...tags.entries()].map(([tag, entries]) => ({
    params: { tag },
    props: { tag, entries },
  }));
}

const { tag, entries } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`All pages tagged "${tag}".`}>
  <div class="mb-4">
    <a href="/tags" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)] font-mono">&larr; All tags</a>
  </div>
  <h1 class="text-2xl font-bold mb-6 font-mono">#{tag} <span class="text-[var(--color-muted)] font-normal text-lg">({entries.length})</span></h1>

  <ContentList items={entries} showSection={true} showDate={true} />
</BaseLayout>
