---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags } from '../../lib/content';

export function getStaticPaths() {
  const tags = getAllTags();
  return [...tags.entries()].map(([tag, entries]) => ({
    params: { tag },
    props: { tag, entries },
  }));
}

const { tag, entries } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`All pages tagged "${tag}".`}>
  <div class="mb-4">
    <a href="/tags" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)]">&larr; All tags</a>
  </div>
  <h1 class="text-2xl font-bold mb-6">#{tag} <span class="text-[var(--color-muted)] font-normal text-lg">({entries.length})</span></h1>

  <div class="space-y-3">
    {entries.map(entry => (
      <a href={`/${entry.section}/${entry.slug}`} class="block group">
        <div class="flex items-center gap-2">
          <span class="text-xs uppercase text-[var(--color-muted)] bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-1.5 py-0.5 rounded">{entry.section}</span>
          <h3 class="font-medium group-hover:text-[var(--color-accent)] dark:group-hover:text-[var(--color-accent-dark)] transition-colors">
            {entry.frontmatter.title || entry.slug}
          </h3>
        </div>
        {entry.frontmatter.description && (
          <p class="text-sm text-[var(--color-muted)] mt-0.5 line-clamp-1">{entry.frontmatter.description}</p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
