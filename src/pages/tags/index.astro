---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags } from '../../lib/content';

const tags = getAllTags();
const sorted = [...tags.entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="Tags" description="Browse all content by tag.">
  <h1 class="text-2xl font-bold mb-6">Tags</h1>

  <div class="flex flex-wrap gap-2">
    {sorted.map(([tag, entries]) => (
      <a href={`/tags/${tag}`} class="inline-flex items-center gap-1 font-mono bg-[var(--color-border)] dark:bg-[var(--color-border-dark)] px-2.5 py-1 hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)] transition-colors text-sm">
        {tag}
        <span class="text-xs text-[var(--color-muted)]">{entries.length}</span>
      </a>
    ))}
  </div>
</BaseLayout>
