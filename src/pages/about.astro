        <tr><td>2019 — 2020</td><td>AI Engineer</td><td>Insense — video quality prediction with CV for influencer marketplace</td></tr>
        <tr><td>2015 — 2019</td><td>CTO / Founder</td><td><a href="/projects/project-life2film">Life2Film</a> — auto video creation from everyday moments, 1M+ users</td></tr>
