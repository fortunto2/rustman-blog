---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from '../../lib/content';

const notes = getCollection('notes');
---

<BaseLayout title="Notes" description="Short thoughts and observations.">
  <h1 class="text-2xl font-bold mb-6">Notes</h1>
  <div class="space-y-6">
    {notes.map(post => (
      <article class="group">
        <a href={`/notes/${post.slug}`} class="block">
          <h3 class="font-medium group-hover:text-[var(--color-accent)] dark:group-hover:text-[var(--color-accent-dark)] transition-colors">
            {post.frontmatter.title || post.slug}
          </h3>
          <div class="flex gap-3 text-xs text-[var(--color-muted)] mt-2">
            <span>{post.frontmatter.created || post.frontmatter.date}</span>
          </div>
        </a>
      </article>
    ))}
    {notes.length === 0 && <p class="text-[var(--color-muted)]">No notes published yet.</p>}
  </div>
</BaseLayout>
