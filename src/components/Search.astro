---
interface Props {
  section?: string;
}
const { section } = Astro.props;
const placeholder = section ? `Search ${section}...` : 'Search...';
---

<div id="search-modal" class="search-modal hidden" data-section={section || ''}>
  <div class="search-overlay"></div>
  <div class="search-container">
    <div class="search-header">
      <input
        type="text"
        id="search-input"
        class="search-input"
        placeholder={placeholder}
        autocomplete="off"
        spellcheck="false"
      />
      <button id="search-close" class="search-close">&times;</button>
    </div>
    <div id="search-results" class="search-results"></div>
    <div class="search-hint">
      <span>esc to close</span>
      <span>/ to open</span>
    </div>
  </div>
</div>

<script is:inline>
  var pagefind = null;
  async function loadPagefind() {
    if (pagefind) return pagefind;
    pagefind = await import('/pagefind/pagefind.js');
    await pagefind.init();
    return pagefind;
  }

  var modal = document.getElementById('search-modal');
  var input = document.getElementById('search-input');
  var results = document.getElementById('search-results');
  var section = modal ? modal.dataset.section : '';
  var debounce;

  function openSearch() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(function() { input.focus(); }, 50);
  }

  function closeSearch() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    results.innerHTML = '';
  }

  // Trigger from nav button
  var btn = document.getElementById('search-trigger');
  if (btn) btn.addEventListener('click', openSearch);

  // Close button
  document.getElementById('search-close').addEventListener('click', closeSearch);

  // Click overlay to close
  modal.querySelector('.search-overlay').addEventListener('click', closeSearch);

  // Keyboard: / to open, Esc to close
  document.addEventListener('keydown', function(e) {
    if (e.key === '/' && ['INPUT', 'TEXTAREA'].indexOf(e.target.tagName) === -1) {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeSearch();
    }
  });

  // Search input
  input.addEventListener('input', function() {
    clearTimeout(debounce);
    debounce = setTimeout(function() { doSearch(input.value); }, 150);
  });

  async function doSearch(query) {
    if (!query || query.length < 2) {
      results.innerHTML = '';
      return;
    }

    var pf = await loadPagefind();
    var filters = section ? { section: [section] } : {};
    var search = await pf.search(query, { filters: filters });

    if (search.results.length === 0) {
      results.innerHTML = '<div class="search-empty">No results for "' + query + '"</div>';
      return;
    }

    var items = await Promise.all(search.results.slice(0, 12).map(function(r) { return r.data(); }));

    results.innerHTML = items.map(function(item) {
      var title = (item.meta && item.meta.title) || item.url;
      var url = item.url || '';
      var parts = url.split('/').filter(Boolean);
      var sec = parts.length > 1 ? parts[0] : '';
      return '<a href="' + url + '" class="search-result-item">' +
        (sec ? '<span class="search-result-section">' + sec + '</span>' : '') +
        '<span class="search-result-title">' + title + '</span></a>';
    }).join('');
  }
</script>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }
  .search-modal.hidden { display: none; }

  .search-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-container {
    position: relative;
    width: 100%;
    max-width: 640px;
    margin: 0 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }

  .search-header {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
  }

  .search-input {
    flex: 1;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: 'JetBrains Mono', monospace;
    background: transparent;
    color: var(--color-text);
    border: none;
    outline: none;
  }
  .search-input::placeholder { color: var(--color-muted); }

  .search-close {
    padding: 0.75rem 1rem;
    font-size: 1.25rem;
    color: var(--color-muted);
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
  }
  .search-close:hover { color: var(--color-text); }

  .search-results {
    overflow-y: auto;
    flex: 1;
  }

  .search-result-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.375rem 1rem;
    text-decoration: none;
    transition: color 0.1s;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
  }
  .search-result-item:hover { color: var(--color-accent); }

  .search-result-section {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-muted);
    flex-shrink: 0;
    width: 4rem;
  }

  .search-result-title {
    color: inherit;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-empty {
    padding: 1.5rem 1rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
  }

  .search-hint {
    display: flex;
    justify-content: space-between;
    padding: 0.4rem 1rem;
    font-size: 0.7rem;
    color: var(--color-muted);
    font-family: 'JetBrains Mono', monospace;
    border-top: 1px solid var(--color-border);
  }

  @media (prefers-color-scheme: dark) {
    .search-container {
      background: var(--color-bg-dark);
      border-color: var(--color-border-dark);
    }
    .search-header { border-color: var(--color-border-dark); }
    .search-input { color: var(--color-text-dark); }
    .search-close:hover { color: var(--color-text-dark); }
    .search-result-item:hover { color: var(--color-accent-dark); }
    .search-hint { border-color: var(--color-border-dark); }
  }
</style>
